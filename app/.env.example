# Qubit web app config. Set these in your host's env (e.g. Vercel project
# settings), NOT in committed code. Unset = devnet.

# Cluster: "devnet" (default) or "mainnet-beta".
VITE_NETWORK=mainnet-beta

# Paid RPC endpoint (the public mainnet RPC is heavily rate-limited).
# Get one from Helius, Triton, QuickNode, etc.
# NOTE: this is a client-side app, so the URL ends up in the browser bundle —
# lock the key to your domain in the provider's dashboard (allowed origins).
VITE_RPC_URL=https://your-rpc-endpoint.example.com
